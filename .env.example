# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this only if your app uses Gemini integration.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where the app is hosted.
APP_URL="https://your-app.onrender.com"

# JWT_SECRET: Private key used to sign and verify JSON Web Tokens for the Admin Panel.
JWT_SECRET="YOUR_JWT_SECRET_KEY"

# MySQL Database connection configuration
# For production, do not use localhost. Provide a managed database host.
MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_USER="root"
MYSQL_PASSWORD="your_password_here"
MYSQL_DATABASE="sai_marketing_db"

# For local development, you may keep MYSQL_HOST=localhost if you have a local MySQL instance.
# For production, set a remote MySQL service host and credentials in your deployment environment.
