# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this only if your app uses Gemini integration.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where the app is hosted.
APP_URL="https://your-app.onrender.com"

# JWT_SECRET: Private key used to sign and verify JSON Web Tokens for the Admin Panel.
JWT_SECRET="YOUR_JWT_SECRET_KEY"

# MongoDB Database connection configuration
# For production, set this to a remote MongoDB connection string (e.g. MongoDB Atlas) in your environment variables.
MONGODB_URI="mongodb://localhost:27017/sai_marketing_db"
